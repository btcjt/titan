{
  "identifier": "default",
  "description": "Default capabilities for Titan browser",
  "windows": ["main"],
  "webviews": ["main", "content"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-title",
    "core:webview:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
